# =============================================================================
#  AI Code Analyzer — environment variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# =============================================================================

# ── Backend ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
DATABASE_URL=postgresql://user:password@host:5432/dbname
GITHUB_TOKEN=your_github_pat_here

# Strong random secret for API key HMAC signing
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=replace_with_64_hex_chars_generated_secret

# Comma-separated origins the backend CORS allows
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Optional overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# MAX_FILE_COUNT=120
# MAX_FILE_SIZE_BYTES=524288

# ── Frontend ──────────────────────────────────────────────────────────────────
# Must point to the publicly reachable backend URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Raw API token generated by: cd backend && python -m app.core.security
NEXT_PUBLIC_API_KEY=your_raw_api_token_here
